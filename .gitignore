# --- 生成物・大容量データ（Git 管理外） ---
/data/
*.pmtiles
*.mbtiles
*.tif
*.tiff
*.geojson
!docs/**/*.geojson
# 参照用のサンプル成果物・Web が読むデータは追跡する（DEM 等の *.tif は除外のまま）
!pipeline/outputs/**/*.geojson
!web/public/data/**/*.geojson

# --- Python (pipeline) ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
.env
.ipynb_checkpoints/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Node / Next.js (web) ---
node_modules/
.next/
out/
.vercel/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS / エディタ ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Web が配信する PMTiles は追跡する
!web/public/data/**/*.pmtiles
